# ─────────────────────────────────────────────────────────────────────────────
# no-circula-bot — Variables de entorno
# Copia este archivo como .env y rellena con tus valores reales.
# NUNCA subas el archivo .env a control de versiones.
# ─────────────────────────────────────────────────────────────────────────────

# ── Telegram ─────────────────────────────────────────────────────────────────
# Token del bot obtenido desde @BotFather en Telegram
TELEGRAM_BOT_TOKEN=

# ID del chat, grupo o canal destino
# Para obtenerlo: envía un mensaje al bot y consulta
# https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=

# ── Vehículo ─────────────────────────────────────────────────────────────────
# Último dígito numérico de tu placa (0-9)
PLACA_ULTIMO_DIGITO=

# Tipo de holograma de verificación: 00, 0, 1 o 2
HOLOGRAMA=

# ── Comportamiento del bot ───────────────────────────────────────────────────
# Enviar notificación solo cuando NO circula (true) o siempre (false)
NOTIFICAR_SOLO_SI_NO_CIRCULA=true

# Nivel de logging: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# ── IA (Groq) ────────────────────────────────────────────────────────────────
# API key gratuita obtenida en https://console.groq.com
# Si no se define, el servicio usa análisis por palabras clave como fallback.
GROQ_API_KEY=

# Modelo de Groq a usar (opcional, tiene valor por defecto)
# Opciones recomendadas: llama-3.3-70b-versatile, llama-3.1-8b-instant, gemma2-9b-it
GROQ_MODEL=llama-3.3-70b-versatile
